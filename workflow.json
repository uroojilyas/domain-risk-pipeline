    {
      "parameters": {
        "jsCode": "// Data process karne ke liye\nfor (const item of $input.all()) {\n    // 1. Google search result se URL nikalna\n    // Yeh check karta hai ke organic_results exist karta hai ya nahi\n    const searchResults = item.json.organic_results;\n    \n    if (searchResults && searchResults.length > 0) {\n        // Pehla result ka link uthaya\n        const rawUrl = searchResults[0].link;\n        \n        // 2. Domain extract karna (e.g., https://www.netflix.com/ -> netflix.com)\n    item.json.Cleaned_URL = rawUrl.toString().replace(/^(https?:\\/\\/)?(www\\.)?/, '').split('/')[0];\n    } else {\n        item.json.Final_Domain = \"No_URL_Found\";\n    }\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
